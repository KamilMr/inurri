---
export const prerender = true;
import Layout from '~/layouts/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Schema from '~/components/layout/Schema.astro';
import PricingTable from '~/components/sections/PricingTable.astro';
import PricingPlan from '~/components/sections/PricingPlan.astro';
import FAQ from '~/components/sections/FAQ.astro';
import { languages } from '~/i18n/ui';
import { useTranslations } from '~/i18n/utils';
import Container from '~/components/ui/Container.astro';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const contactHref = (serviceId: string) => `/${lang}/contact?service=${encodeURIComponent(serviceId)}`;

const plans = [
  {
    key: 'starter',
    name: t['pricing.starter.name'],
    price: 1200,
    displayPrice: t['pricing.starter.price'],
    description: t['pricing.starter.desc'],
    features: [
      t['pricing.starter.item1'],
      t['pricing.starter.item2'],
      t['pricing.starter.item3'],
      t['pricing.starter.item4'],
      t['pricing.starter.item5'],
      t['pricing.starter.item6'],
      t['pricing.starter.item7'],
      t['pricing.starter.item8'],
      t['pricing.starter.item9'],
      t['pricing.starter.item10'],
    ],
    cta: t['pricing.cta.contact'],
  },
  {
    key: 'recommended',
    name: t['pricing.recommended.name'],
    price: 4800,
    displayPrice: t['pricing.recommended.price'],
    description: t['pricing.recommended.desc'],
    features: [
      t['pricing.recommended.item1'],
      t['pricing.recommended.item2'],
      t['pricing.recommended.item3'],
      t['pricing.recommended.item4'],
      t['pricing.recommended.item5'],
      t['pricing.recommended.item6'],
      t['pricing.recommended.item7'],
      t['pricing.recommended.item8'],
      t['pricing.recommended.item9'],
      t['pricing.recommended.item10'],
      t['pricing.recommended.item11'],
      t['pricing.recommended.item12'],
    ],
    cta: t['pricing.cta.contact'],
    popular: true,
  },
  {
    key: 'app',
    name: t['pricing.app.name'],
    price: 12000,
    displayPrice: t['pricing.app.price'],
    description: t['pricing.app.desc'],
    features: [
      t['pricing.app.item1'],
      t['pricing.app.item2'],
      t['pricing.app.item3'],
      t['pricing.app.item4'],
      t['pricing.app.item5'],
      t['pricing.app.item6'],
    ],
    cta: t['pricing.cta.contact'],
  },
];

const faqs = [
  { question: t['faq.pricing.1.q'], answer: t['faq.pricing.1.a'] },
  { question: t['faq.pricing.2.q'], answer: t['faq.pricing.2.a'] },
  { question: t['faq.pricing.3.q'], answer: t['faq.pricing.3.a'] },
  { question: t['faq.pricing.4.q'], answer: t['faq.pricing.4.a'] },
  { question: t['faq.pricing.5.q'], answer: t['faq.pricing.5.a'] },
  { question: t['faq.pricing.6.q'], answer: t['faq.pricing.6.a'] },
];

const supportPlans = [
  {
    name: t['pricing.care.start.name'],
    hours: t['pricing.care.start.hours'],
    price: t['pricing.care.start.price'],
    description: t['pricing.care.start.desc'],
  },
  {
    name: t['pricing.care.growth.name'],
    hours: t['pricing.care.growth.hours'],
    price: t['pricing.care.growth.price'],
    discount: t['pricing.care.growth.discount'],
    description: t['pricing.care.growth.desc'],
  },
  {
    name: t['pricing.care.priority.name'],
    hours: t['pricing.care.priority.hours'],
    price: t['pricing.care.priority.price'],
    discount: t['pricing.care.priority.discount'],
    description: t['pricing.care.priority.desc'],
  },
];

const pricingSteps = [
  {
    title: t['pricing.process.step1.title'],
    description: t['pricing.process.step1.desc'],
  },
  {
    title: t['pricing.process.step2.title'],
    description: t['pricing.process.step2.desc'],
  },
  {
    title: t['pricing.process.step3.title'],
    description: t['pricing.process.step3.desc'],
  },
];
---

<Layout title={t['pricing.meta.title']} description={t['pricing.meta.desc']}>
  <Schema item={{
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Inurri",
    "description": t['pricing.meta.desc'],
    "offers": plans.map(plan => ({
      "@type": "Offer",
      "name": plan.name,
      "price": String(plan.price),
      "priceCurrency": "PLN",
      "description": plan.description,
      "url": new URL(`/${lang}/pricing`, Astro.site).toString()
    }))
  }} />

  <PageHeader 
      title={t['pricing.title']}
      description={t['pricing.subtitle']}
  />

  <Container as="section" class="pb-24">
      <PricingTable>
        {plans.map(plan => (
          <PricingPlan
            name={plan.name}
            price={plan.displayPrice}
            description={plan.description}
            features={plan.features}
            cta={plan.cta}
            popular={plan.popular}
            ctaHref={contactHref(plan.key)}
          />
        ))}
      </PricingTable>

      <div class="mt-12 rounded-3xl border border-foreground/10 bg-black/5 dark:bg-white/5 p-6 md:p-8">
        <div class="mb-6 max-w-2xl">
          <p class="text-sm uppercase tracking-[0.2em] text-primary font-semibold mb-2">{t['pricing.process.eyebrow']}</p>
          <h2 class="text-2xl md:text-3xl font-display font-bold mb-3">{t['pricing.process.title']}</h2>
          <p class="text-muted-foreground">{t['pricing.process.desc']}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {pricingSteps.map((step, index) => (
            <div class="rounded-2xl border border-foreground/10 bg-background/80 p-5">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-primary">
                {index + 1}
              </div>
              <h3 class="font-bold mb-2">{step.title}</h3>
              <p class="text-sm text-muted-foreground">{step.description}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-20">
        <div class="text-center max-w-3xl mx-auto mb-10">
          <p class="text-sm uppercase tracking-[0.2em] text-primary font-semibold mb-2">{t['pricing.care.eyebrow']}</p>
          <h2 class="text-3xl md:text-5xl font-display font-bold mb-4" set:html={t['pricing.care.title']} />
          <p class="text-muted-foreground">{t['pricing.care.desc']}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {supportPlans.map((plan) => (
            <div class="rounded-3xl border border-foreground/10 bg-black/5 dark:bg-white/5 p-6">
              <div class="flex items-center justify-between gap-3 mb-3">
                <div class="text-sm font-semibold text-primary">{plan.hours}</div>
                {plan.discount && (
                  <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-bold text-primary">
                    {plan.discount}
                  </span>
                )}
              </div>
              <h3 class="text-xl font-bold mb-2">{plan.name}</h3>
              <p class="text-2xl font-display font-bold mb-4">{plan.price}</p>
              <p class="text-sm text-muted-foreground">{plan.description}</p>
            </div>
          ))}
        </div>
      </div>
      
      <div class="mt-20">
          <FAQ items={faqs} />
      </div>
  </Container>
</Layout>
