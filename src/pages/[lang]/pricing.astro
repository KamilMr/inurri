---
export const prerender = true;
import Layout from '~/layouts/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Schema from '~/components/layout/Schema.astro';
import PricingTable from '~/components/sections/PricingTable.astro';
import PricingPlan from '~/components/sections/PricingPlan.astro';
import FAQ from '~/components/sections/FAQ.astro';
import { languages } from '~/i18n/ui';
import { useTranslations } from '~/i18n/utils';
import Container from '~/components/ui/Container.astro';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const contactHref = `/${lang}/contact`;

const plans = [
  {
    key: 'starter',
    name: t['pricing.starter.name'],
    price: 1200,
    displayPrice: t['pricing.starter.price'],
    description: t['pricing.starter.desc'],
    features: [
      t['pricing.starter.item1'],
      t['pricing.starter.item2'],
      t['pricing.starter.item3'],
      t['pricing.starter.item4'],
    ],
    cta: t['pricing.cta.contact'],
  },
  {
    key: 'recommended',
    name: t['pricing.recommended.name'],
    price: 4800,
    displayPrice: t['pricing.recommended.price'],
    description: t['pricing.recommended.desc'],
    features: [
      t['pricing.recommended.item1'],
      t['pricing.recommended.item2'],
      t['pricing.recommended.item3'],
      t['pricing.recommended.item4'],
    ],
    cta: t['pricing.cta.contact'],
    popular: true,
  },
  {
    key: 'app',
    name: t['pricing.app.name'],
    price: 12000,
    displayPrice: t['pricing.app.price'],
    description: t['pricing.app.desc'],
    features: [
      t['pricing.app.item1'],
      t['pricing.app.item2'],
      t['pricing.app.item3'],
      t['pricing.app.item4'],
    ],
    cta: t['pricing.cta.contact'],
  },
];

const faqs = [
  { question: t['faq.pricing.1.q'], answer: t['faq.pricing.1.a'] },
  { question: t['faq.pricing.2.q'], answer: t['faq.pricing.2.a'] },
  { question: t['faq.pricing.3.q'], answer: t['faq.pricing.3.a'] },
  { question: t['faq.pricing.4.q'], answer: t['faq.pricing.4.a'] },
];
---

<Layout title={t['pricing.meta.title']} description={t['pricing.meta.desc']}>
  <Schema item={{
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Inurri",
    "description": t['pricing.meta.desc'],
    "offers": plans.map(plan => ({
      "@type": "Offer",
      "name": plan.name,
      "price": String(plan.price),
      "priceCurrency": "PLN",
      "description": plan.description,
      "url": new URL(`/${lang}/pricing`, Astro.site).toString()
    }))
  }} />

  <PageHeader 
      title={t['pricing.title']}
      description={t['pricing.subtitle']}
  />

  <Container as="section" class="pb-24">
      <div class="mb-10 rounded-3xl border border-primary/20 bg-primary/5 p-6 text-center">
        <p class="text-sm uppercase tracking-[0.2em] text-primary font-semibold mb-2">{t['pricing.rate.label']}</p>
        <p class="text-3xl md:text-4xl font-display font-bold">{t['pricing.rate.value']}</p>
        <p class="mt-3 text-muted-foreground max-w-2xl mx-auto">{t['pricing.rate.desc']}</p>
      </div>

      <PricingTable>
        {plans.map(plan => (
          <PricingPlan
            name={plan.name}
            price={plan.displayPrice}
            description={plan.description}
            features={plan.features}
            cta={plan.cta}
            popular={plan.popular}
            ctaHref={contactHref}
          />
        ))}
      </PricingTable>
      
      <div class="mt-20">
          <FAQ items={faqs} />
      </div>
  </Container>
</Layout>
