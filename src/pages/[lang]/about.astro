---

<Layout title={t['about.meta.title']} description={t['about.meta.desc']}>
<PageHeader title={t['about.title']} description={t['about.mission']} />

  <Container as="section" class="py-24">
    <div class="max-w-3xl mx-auto">
      <Heading level={2} class="mb-6">{t['about.story.title']}</Heading>
      <div class="space-y-4 text-muted-foreground">
        <Text>{t['about.story.p1']}</Text>
        <a
          href="https://kamilmrowka.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex font-medium text-primary hover:text-primary/80 transition-colors"
        >
          {t['about.story.link']}
        </a>
      </div>
    </div>
  </Container>

  {/* Image-backed story section is kept for later reuse, but hidden now so the image is not accessed.
