---
export const prerender = true;
import Layout from '~/layouts/Layout.astro';
import ContactForm from '~/components/islands/ContactForm';
import { Clock, ListChecks, Mail, MessageSquare } from 'lucide-react';
import PageHeader from '~/components/layout/PageHeader.astro';
import Container from '~/components/ui/Container.astro';
import Grid from '~/components/ui/Grid.astro';
import { languages } from '~/i18n/ui';
import { useTranslations } from '~/i18n/utils';
import { siteConfig } from '~/site.config';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const contactEmail = siteConfig.contact.email.support;

const formLabels = {
  name: t['contact.form.name'],
  email: t['contact.form.email'],
  service: t['contact.form.service'],
  message: t['contact.form.message'],
  namePlaceholder: t['contact.form.name.placeholder'],
  emailPlaceholder: t['contact.form.email.placeholder'],
  servicePlaceholder: t['contact.form.service.placeholder'],
  messagePlaceholder: t['contact.form.message.placeholder'],
  submit: t['contact.form.submit'],
  sending: t['contact.form.sending'],
  successTitle: t['contact.form.success.title'],
  successDescription: t['contact.form.success.desc'],
  successAction: t['contact.form.success.action'],
  errorSubmit: t['contact.form.error.submit'],
  requiredName: t['contact.form.error.name'],
  requiredEmail: t['contact.form.error.email'],
  invalidEmail: t['contact.form.error.email.invalid'],
  requiredMessage: t['contact.form.error.message'],
};

const serviceOptions = [
  {
    id: 'starter',
    label: t['pricing.starter.name'],
    messageIntro: t['contact.prefill.starter.intro'],
    messageRequest: t['contact.prefill.request'],
  },
  {
    id: 'recommended',
    label: t['pricing.recommended.name'],
    messageIntro: t['contact.prefill.recommended.intro'],
    messageRequest: t['contact.prefill.request'],
  },
  {
    id: 'app',
    label: t['pricing.app.name'],
    messageIntro: t['contact.prefill.app.intro'],
    messageRequest: t['contact.prefill.request'],
  },
];
---

<Layout title={t['contact.meta.title']} description={t['contact.meta.desc']}>
  <PageHeader 
      title={t['contact.title']}
      description={t['contact.desc']}
  />

  <Container as="section" class="pb-24">
      <Grid cols={2} class="gap-12">
          <!-- Contact Guidance -->
          <div class="space-y-8">
              <div>
                  <p class="text-sm font-medium uppercase tracking-[0.2em] text-primary mb-3">{t['contact.info.eyebrow']}</p>
                  <h2 class="text-2xl font-bold mb-4">{t['contact.info.title']}</h2>
                  <p class="text-muted-foreground max-w-md">{t['contact.info.desc']}</p>
              </div>
              
              <div class="space-y-5">
                  <div class="flex items-start gap-4">
                      <div class="p-3 rounded-lg bg-primary/10 text-primary">
                          <Mail className="w-6 h-6" />
                      </div>
                      <div>
                          <h3 class="font-bold mb-1">{t['contact.info.email.title']}</h3>
                          <p class="text-muted-foreground mb-1">{t['contact.info.email.desc']}</p>
                          <a href={`mailto:${contactEmail}`} class="font-medium text-primary hover:text-primary/80 transition-colors">
                              {contactEmail}
                          </a>
                      </div>
                  </div>

                  <div class="flex items-start gap-4">
                      <div class="p-3 rounded-lg bg-primary/10 text-primary">
                          <MessageSquare className="w-6 h-6" />
                      </div>
                      <div>
                          <h3 class="font-bold mb-1">{t['contact.info.idea.title']}</h3>
                          <p class="text-muted-foreground">{t['contact.info.idea.desc']}</p>
                      </div>
                  </div>

                  <div class="flex items-start gap-4">
                      <div class="p-3 rounded-lg bg-primary/10 text-primary">
                          <ListChecks className="w-6 h-6" />
                      </div>
                      <div>
                          <h3 class="font-bold mb-1">{t['contact.info.scope.title']}</h3>
                          <p class="text-muted-foreground">{t['contact.info.scope.desc']}</p>
                      </div>
                  </div>

                  <div class="flex items-start gap-4">
                      <div class="p-3 rounded-lg bg-primary/10 text-primary">
                          <Clock className="w-6 h-6" />
                      </div>
                      <div>
                          <h3 class="font-bold mb-1">{t['contact.info.reply.title']}</h3>
                          <p class="text-muted-foreground">{t['contact.info.reply.desc']}</p>
                      </div>
                  </div>
              </div>
          </div>

          <!-- Contact Form -->
          <div>
              <form name="contact" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" hidden>
                  <input type="hidden" name="form-name" value="contact" />
                  <input type="text" name="name" />
                  <input type="email" name="email" />
                  <select name="service">
                    {serviceOptions.map((option) => <option value={option.id}>{option.label}</option>)}
                  </select>
                  <textarea name="message"></textarea>
                  <input name="bot-field" />
              </form>
              <ContactForm labels={formLabels} serviceOptions={serviceOptions} endpoint={`/${lang}/contact/`} client:only="react" />
          </div>
      </Grid>
  </Container>
</Layout>
