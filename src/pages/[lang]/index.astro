---
export const prerender = true;
import { languages, defaultLang } from '~/i18n/ui';
import Layout from '~/layouts/Layout.astro';
import Schema from '~/components/layout/Schema.astro';
import HomeContent from '~/components/sections/HomeContent.astro';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang = defaultLang } = Astro.params;

const pageTitle = lang === 'pl'
    ? 'Inurri — Rozwiązania webowe | Frontend, Backend, Chmura'
    : 'Inurri — Web solutions | Frontend, Backend, Cloud';
const pageDescription = lang === 'pl'
    ? 'Tworzę rozwiązania webowe dostosowane do Twoich potrzeb - od stron wizytówek po zaawansowane aplikacje. Frontend, backend, chmura i integracje systemów.'
    : 'I build web solutions tailored to your needs - from business-card websites to advanced applications. Frontend, backend, cloud, and system integrations.';
---

<Layout title={pageTitle} description={pageDescription}>
    <Schema item={{
            "@context": "https://schema.org",
            "@type": "WebSite",
            "name": "Inurri",
            "url": Astro.site,
            "inLanguage": lang
        }} />
    <Schema item={{
            "@context": "https://schema.org",
            "@type": "ProfessionalService",
            "name": "Inurri",
            "url": Astro.site,
            "description": pageDescription,
            "areaServed": "PL",
            "serviceType": [
                "Strony internetowe",
                "Aplikacje internetowe",
                "Automatyzacja i integracja",
                "Rozwiązania chmurowe"
            ]
        }} />

    <HomeContent lang={lang} heroVariant="centered" />
</Layout>
